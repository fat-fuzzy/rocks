{
	"layout": {
		"$type": "dimension",
		"unit": "rem",
		"base": {
			"value": 1
		},
		"gap": {
			"$type": "dimension",
			"unit": "rem",
			"4xs": {
				"value": "{size.base.4xs}"
			},
			"3xs": {
				"value": "{size.base.3xs}"
			},
			"2xs": {
				"value": "{size.base.2xs}"
			},
			"xs": {
				"value": "{size.base.xs}"
			},
			"sm": {
				"value": "{size.base.sm}"
			},
			"md": {
				"value": "{size.base.md}"
			},
			"lg": {
				"value": "{size.base.lg}"
			},
			"xl": {
				"value": "{size.base.xl}"
			},
			"2xl": {
				"value": "{size.base.2xl}"
			},
			"3xl": {
				"value": "{size.base.3xl}"
			},
			"4xl": {
				"value": "{size.base.4xl}"
			}
		},
		"sidebar": {
			"$type": "dimension",
			"unit": "rem",
			"base": {
				"value": "16"
			},
			"hidden": {
				"value": "0"
			},
			"collapsed": {
				"value": "6.5"
			},
			"2xs": {
				"value": "8"
			},
			"xs": {
				"value": "12"
			},
			"sm": {
				"value": "14"
			},
			"md": {
				"value": "{layout.sidebar.base.value}"
			},
			"lg": {
				"value": "22"
			},
			"xl": {
				"value": "24"
			},
			"2xl": {
				"value": "28"
			},
			"3xl": {
				"value": "36"
			}
		},
		"grid": {
			"$type": "dimension",
			"unit": "rem",
			"item": {
				"3xs": {
					"value": "5"
				},
				"2xs": {
					"value": "7"
				},
				"xs": {
					"value": "10"
				},
				"sm": {
					"value": "15"
				},
				"md": {
					"value": "20"
				},
				"lg": {
					"value": "25"
				},
				"xl": {
					"value": "30"
				},
				"2xl": {
					"value": "35"
				}
			}
		},
		"breakpoint": {
			"$type": "dimension",
			"unit": "rem",
			"2xs": {
				"value": "20"
			},
			"xs": {
				"value": "38.75"
			},
			"sm": {
				"value": "58.45"
			},
			"md": {
				"value": "85"
			},
			"lg": {
				"value": "101.25"
			},
			"xl": {
				"value": "128"
			},
			"2xl": {
				"value": "190.5"
			}
		},
		"threshold": {
			"$type": "dimension",
			"unit": "rem",
			"3xs": {
				"value": "{layout.sidebar.collapsed}"
			},
			"2xs": {
				"value": "{layout.breakpoint.2xs}"
			},
			"xs": {
				"value": "{layout.breakpoint.xs}"
			},
			"sm": {
				"value": "{layout.breakpoint.sm}"
			},
			"md": {
				"value": "{layout.breakpoint.md}"
			},
			"lg": {
				"value": "{layout.breakpoint.lg}"
			},
			"xl": {
				"value": "{layout.breakpoint.xl}"
			},
			"2xl": {
				"value": "{layout.breakpoint.2xl}"
			}
		},
		"z-index": {
			"$type": "number",
			"0": {
				"$value": 0
			},
			"1": {
				"$value": 1
			},
			"2": {
				"$value": 2
			},
			"3": {
				"$value": 3
			},
			"4": {
				"$value": 4
			},
			"5": {
				"$value": 5
			},
			"inset": {
				"$value": "{layout.z-index.0}"
			},
			"layer": {
				"$value": "{layout.z-index.1}"
			},
			"sticky": {
				"$value": "{layout.z-index.2}"
			},
			"reveal": {
				"$value": "{layout.z-index.3}"
			},
			"fixed": {
				"$value": "{layout.z-index.4}"
			},
			"overlay": {
				"$value": "{layout.z-index.5}"
			}
		}
	},
	"overlay": {
		"$type": "derived",
		"height": {
			"3xs": {
				"$value": "calc(14vh - 2 * var(--ui-size))"
			},
			"2xs": {
				"$value": "calc(20vh - 2 * var(--ui-size))"
			},
			"xs": {
				"$value": "calc(30vh - 2 * var(--ui-size))"
			},
			"sm": {
				"$value": "calc(40vh - 2 * var(--ui-size))"
			},
			"md": {
				"$value": "calc(64vh - 2 * var(--ui-size))"
			},
			"lg": {
				"$value": "calc(76vh - 2 * var(--ui-size))"
			},
			"xl": {
				"$value": "calc(100vh - var(--ui-header-height) - 2 * var(--ui-size) - var(--outline-offset-lg))"
			}
		}
	}
}
