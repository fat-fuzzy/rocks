{
	"package": "@fat-fuzzy/playbook",
	"name": "@fat-fuzzy/playbook",
	"version": "0.1.29",
	"description": "A UI library explorer and demo",
	"author": "Patricia Boh",
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && pnpm package",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && publint",
		"test": "pnpm test:e2e",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:ui": "NODE_ENV=test playwright test --ui",
		"test:e2e": "NODE_ENV=test playwright test",
		"test:report": "NODE_ENV=test playwright test --reporter=html",
		"test:unit": "vitest run"
	},
	"main": "./dist/index.js",
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./api": "./dist/index.js"
	},
	"peerDependencies": {
		"@sveltejs/kit": "2.53.4",
		"svelte": "5.53.5"
	},
	"devDependencies": {
		"@eslint/compat": "2.0.3",
		"@fat-fuzzy/config": "workspace:*",
		"@fat-fuzzy/style": "workspace:*",
		"@fat-fuzzy/ui": "workspace:*",
		"@playwright/test": "1.58.2",
		"@sveltejs/adapter-cloudflare": "7.2.8",
		"@sveltejs/kit": "2.53.4",
		"@sveltejs/package": "2.5.7",
		"@sveltejs/vite-plugin-svelte": "6.2.4",
		"publint": "0.3.18",
		"svelte": "5.53.7",
		"svelte-check": "4.4.5",
		"tslib": "2.8.1",
		"typescript": "5.9.3",
		"vite": "7.3.1",
		"vitest": "4.0.18"
	},
	"type": "module"
}
